# settings.toml - CircuitPython configuration
# Copy this file to the CIRCUITPY drive root as settings.toml

# ----- Wi-Fi credentials -----
CIRCUITPY_WIFI_SSID     = "YourWiFiName"
CIRCUITPY_WIFI_PASSWORD = "YourWiFiPassword"

# ----- MTA Station Config -----
# Comma-separated list of stop configs to monitor.
# Format per entry: stop_id:line:direction
#   stop_id   = GTFS stop ID (find yours in MTA GTFS static feed stops.txt)
#   line      = subway line letter/number (optional - omit to match any line)
#   direction = N (northbound) or S (southbound) (optional - omit for both)
#
# Examples:
#   "721:7:N"            = 7 train Manhattan-bound at Vernon Blvd-Jackson Av
#   "G24:G:S"            = G train Brooklyn-bound at 21 St
#   "G22"                = any line, any direction at Court Sq
#   "721:7:N,G24:G:S"    = both of the above
#
# The soonest arrivals across all configs fill rows 1 and 2.
MTA_STOPS = "721:7:N,G24:G:S"

# How often to refresh data (seconds)
MTA_REFRESH_INTERVAL = "30"

# Number of train rows to display (max 2 for 128x32)
MTA_NUM_ROWS = "2"

# Display brightness (0.0 to 1.0)
MTA_BRIGHTNESS = "0.12"

# ----- Clock Mode -----
# Fallback UTC offset if weather hasn't run yet
# (auto-detected from zip code once weather mode runs)
CLOCK_TZ_OFFSET = "-5"

# ----- Weather Mode -----
# US zip code - sets weather location and auto-detects timezone
WEATHER_ZIP = "10001"

# ----- Stocks Mode -----
# Comma-separated ticker symbols
STOCK_SYMBOLS = "AAPL,GOOGL,MSFT"
